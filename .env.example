# Shared platform configuration
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0

# Postgres / Redis
DATABASE_URL=postgresql://verifund:verifund_secret@postgres:5432/verifund
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRY_HOURS=24

# Squad (sandbox or live)
SQUAD_SECRET_KEY=
SQUAD_PUBLIC_KEY=
SQUAD_WEBHOOK_SECRET=
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
SQUAD_REQUEST_TIMEOUT=15
SQUAD_DIRECT_DEBIT_PATH=/transaction/mandate/create
SQUAD_REDIRECT_URL=
SQUAD_WEBHOOK_URL=
SQUAD_SETTLEMENT_ACCOUNT=
SQUAD_SETTLEMENT_MOBILE=
SQUAD_SETTLEMENT_EMAIL=
SQUAD_SETTLEMENT_ADDRESS=
SQUAD_SETTLEMENT_DOB=
SQUAD_SETTLEMENT_GENDER=
ALLOW_UNVERIFIED_WEBHOOKS=True

# AI (optional — enables LLM whistleblower triage on the AI service)
OPENROUTER_API_KEY=

# Email notifications (Python smtplib — no third-party SMS API)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
DEFAULT_NOTIFICATION_EMAIL=
SMTP_USE_TLS=true

# --- Railway: set on the BACKEND service ---
# AI_SERVICE_URL=https://your-ai-service.up.railway.app
#
# --- Railway: set on the AI service ---
# DATABASE_URL, JWT_SECRET, SECRET_KEY, ALLOWED_HOSTS=*, DEBUG=False
# OPENROUTER_API_KEY (optional)

# Internal service routing (local/docker-compose)
MEMBER_SERVICE_URL=http://member-service:8001
COOPERATIVE_SERVICE_URL=http://cooperative-service:8002
CONTRIBUTION_SERVICE_URL=http://contribution-service:8003
WITHDRAWAL_SERVICE_URL=http://withdrawal-service:8004
AI_SERVICE_URL=http://127.0.0.1:8005
NOTIFICATION_SERVICE_URL=http://127.0.0.1:8006

# Workflow thresholds
MIN_WITHDRAWAL_SIGNERS=3
AI_RISK_BLOCK_THRESHOLD=0.85
