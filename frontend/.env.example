# Frontend environment example for VeriFund
# Copy to .env or set the following variables in your hosting provider.

# Base URL for the backend API the frontend should talk to
# Example: https://verifund-production-0ae5.up.railway.app
VITE_API_URL=VITE_API_URL

# Optional toggles you can enable for local demos
# VITE_ENABLE_MOCK=false

# App/title used in some build scripts or meta tags
# VITE_APP_NAME=VeriFund
